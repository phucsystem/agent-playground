NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Initial admin token — use this to login for the first time
# After login, you can create more tokens via Supabase dashboard
ADMIN_INITIAL_TOKEN=

# GIF search (GIPHY API — free at https://developers.giphy.com/)
NEXT_PUBLIC_GIPHY_API_KEY=

# Webhook secret for release notifications (generate with: openssl rand -hex 32)
RELEASE_WEBHOOK_SECRET=

# GoClaw integration (for AI agent bridge)
GOCLAW_URL=https://your-goclaw-server.com
GOCLAW_GATEWAY_TOKEN=your-gateway-token

# GoClaw URL (public, for auto-fill in admin UI)
NEXT_PUBLIC_GOCLAW_URL=https://your-goclaw-server.com

# Test user tokens (from seed data)
# Alice: tok-alice-002
# Bob: tok-bob-003
# Claude Agent: tok-claude-agent-001
# GPT-4 Agent: tok-gpt4-agent-002
